    {
      "name": "Documents - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "title",
              "value": "Budget Q1",
              "type": "text"
            },
            {
              "key": "description",
              "value": "Quarterly budget proposal",
              "type": "text"
            },
            {
              "key": "department",
              "value": "Finance",
              "type": "text"
            },
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/documents",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "documents"
          ]
        }
      }
    },
    {
      "name": "Documents - List with Filters",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/documents?search=budget&status=Under%20Review&department=Finance",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "documents"
          ],
          "query": [
            {
              "key": "search",
              "value": "budget"
            },
            {
              "key": "status",
              "value": "Under Review"
            },
            {
              "key": "department",
              "value": "Finance"
            }
          ]
        }
      }
    },
    {
      "name": "Workflow - Forward",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"Forward\",\n  \"targetDepartment\": \"Operations\",\n  \"remarks\": \"Need ops review\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/workflow/{{documentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "workflow",
            "{{documentId}}"
          ]
        }
