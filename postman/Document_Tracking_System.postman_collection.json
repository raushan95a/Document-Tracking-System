        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"employee_1\",\n  \"name\": \"Employee One\",\n  \"email\": \"employee1@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"employee\",\n  \"department\": \"Finance\"\n}"
        },
        "url": {
